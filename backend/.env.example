UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
DB_PATH=droneseg.db
SAMPLE_IMAGE_DIR=sample_images
MODEL_ID=nvidia/segformer-b2-finetuned-ade-512-512
MAX_UPLOAD_SIZE_MB=50
MAX_INFERENCE_SIDE=1280
MIN_AREA_RATIO=0.001
CORS_ORIGINS=http://localhost:3000
LOAD_MODEL_ON_STARTUP=true

# Optional LLM mode. Keep false/empty to run the free SegFormer mode only.
ENABLE_LLM=false
OPENAI_API_KEY=

# Default image placement when sample_bounds.json or manual frontend bounds are not supplied.
DEFAULT_SW_LNG=90.354
DEFAULT_SW_LAT=23.778
DEFAULT_NE_LNG=90.358
DEFAULT_NE_LAT=23.782
